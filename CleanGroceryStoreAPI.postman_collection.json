        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r\n    pm.response.to.have.status(200);\r\n});\r\n\r\nconst response = pm.response.json();\r\n\r\npm.test(\"Product object\", () => { \r\n    pm.expect(response).to.be.an('object');\r\n    console.log(response.name);\r\n})\r\n\r\npm.test('Correct product was retrived', () => {\r\n    pm.expect(response.id).to.eql(pm.collectionVariables.get('productId'));\r\n})\r\n\r\npm.test(\"Product name\", () => {\r\n    pm.expect(response.name).to.eql(\"Don Francisco Colombia Supremo Medium Roast\");\r\n    pm.expect(response.name).to.be.a('string');\r\n    console.log(response.name);\r\n})\r\n\r\npm.test(\"Product price\", () => {\r\n    pm.expect(response.price).to.be.a('number');\r\n    pm.expect(response.price).to.be.above(0);\r\n    console.log(response.price);\r\n})\r\n\r\npm.test(\"Product is in stock\", () => {\r\n    pm.expect(response.inStock).to.be.true;\r\n    console.log(response.inStock);\r\n})"
